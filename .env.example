# 复制为 .env 后填入真实值。.env 永不进 Git。

# === 运行环境 ===
# development 时启用 POST /auth/dev-login 登录旁路；生产务必置 production（旁路返 404）
NODE_ENV=development

# === 数据库 ===
DATABASE_URL=postgresql://user:pass@localhost:5432/maisimei

# === 微信小程序 ===
WX_APPID=
WX_APPSECRET=

# === JWT ===
JWT_SECRET=
JWT_EXPIRES_IN=7d

# === 对象存储（阿里云 OSS 或华为云 OBS）===
OSS_REGION=
OSS_BUCKET=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_ENDPOINT=

# === AI 视觉（Chester 提供旧版 API）===
AI_VISION_PROVIDER=
AI_VISION_ENDPOINT=
AI_VISION_API_KEY=

# === OCR（同上厂商）===
OCR_ENDPOINT=
OCR_API_KEY=

# === 后台 ===
ADMIN_DEFAULT_PASSWORD=
