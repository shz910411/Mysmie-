<view class="screen">
  <view class="brandbar center">
    <image class="logo" src="/images/logo-mark.png" mode="heightFix" />
  </view>

  <view class="row" style="margin-top:14px">
    <text class="eyebrow">{{todayDate}}</text>
    <view class="linklike bell" bindtap="onNotices">通知<text class="bell-dot"></text></view>
  </view>

  <!-- 视觉中心：今晨体重 -->
  <view class="hero">
    <view class="eyebrow">今晨体重</view>
    <view class="hero-num">
      <text wx:if="{{hasToday}}" class="mega">{{weight}}<text class="unit">kg</text></text>
      <text wx:else class="mega none">今天还没称</text>
    </view>
  </view>

  <button class="btn" hover-class="btn-hover" bindtap="onStartWeigh">开始称重</button>
  <view class="ctr-link"><text class="linklike" bindtap="onManual">没带秤？手动记录</text></view>
  <view class="privacy-note">数据仅自己与你授权的人可见</view>

  <!-- 近七天趋势 -->
  <view class="card">
    <view class="row"><text class="eyebrow">近七天</text><text class="muted mini">晨起记录</text></view>
    <view wx:if="{{spark.length}}" class="spark spark-mt">
      <view wx:for="{{spark}}" wx:key="index" class="bar {{item.hl ? 'hl' : ''}}" style="height:{{item.h}}px"></view>
    </view>
    <view wx:else class="muted mini spark-mt">还没有记录，先称一次吧</view>
  </view>

  <!-- 今日摄入（M3 填真实）-->
  <view class="card">
    <view class="row">
      <text class="eyebrow">今日摄入</text>
      <text class="kcal">0 <text class="kcal-unit">KCAL · 估算</text></text>
    </view>
    <view class="meal-mini">
      <view class="m"><text class="v">—</text><text class="k">早</text></view>
      <view class="m"><text class="v">—</text><text class="k">午</text></view>
      <view class="m"><text class="v">—</text><text class="k">晚</text></view>
      <view class="m"><text class="v">—</text><text class="k">加</text></view>
    </view>
    <view class="ctr-link"><text class="linklike" bindtap="onCamera">拍照打卡，AI 帮你看吃了什么</text></view>
  </view>

  <!-- 饮水/排便/睡眠（M2 静态占位）-->
  <view class="card">
    <view class="row three">
      <view class="metric"><text class="eyebrow flat">饮水</text><text class="mv">0</text><text class="muted mini">杯</text></view>
      <view class="metric"><text class="eyebrow flat">排便</text><text class="mv">0</text><text class="muted mini">次</text></view>
      <view class="metric"><text class="eyebrow flat">睡眠</text><text class="mv">—</text><text class="muted mini">小时</text></view>
    </view>
  </view>

  <!-- 我服务的人（M5 填真实）-->
  <view class="card" bindtap="onService">
    <view class="row">
      <view><text class="row-title">我服务的人</text><view class="muted mini gap">共享与服务视图将于后续开放</view></view>
      <text class="linklike">查看</text>
    </view>
  </view>

  <!-- 今日汇总 -->
  <view class="card" bindtap="onSummary">
    <view class="row">
      <view><text class="row-title">今日汇总与分享</text><view class="muted mini gap">全维度日报，一键转发到伙伴群</view></view>
      <text class="linklike">进入</text>
    </view>
  </view>
</view>
