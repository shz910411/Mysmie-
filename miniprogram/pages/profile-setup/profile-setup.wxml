<view class="screen">
  <view class="brandbar">
    <image class="logo" src="/images/logo-mark.png" mode="heightFix" />
    <view class="bt"><text class="wm">MYSMIE</text><text class="cn">迈思美</text></view>
  </view>

  <view class="h-title mt">30 秒建档</view>
  <view class="h-sub">只需 3 项 —— 体重不用填，上秤称一下就知道了。</view>

  <view class="card">
    <text class="fld">性别</text>
    <view class="portion gender">
      <view class="i {{gender === 'female' ? 'on' : ''}}" data-g="female" bindtap="onGender">女</view>
      <view class="i {{gender === 'male' ? 'on' : ''}}" data-g="male" bindtap="onGender">男</view>
      <view class="i {{gender === 'other' ? 'on' : ''}}" data-g="other" bindtap="onGender">其他</view>
    </view>

    <text class="fld">年龄</text>
    <input class="input full" type="number" value="{{age}}" bindinput="onAge" />

    <text class="fld">身高 (cm)</text>
    <input class="input full" type="number" value="{{height}}" bindinput="onHeight" />
  </view>

  <button class="btn" bindtap="onSubmit">完成，去称一下</button>
</view>
