page {
  background: #FAFBF2;
  color: #233710;
  font-family: "HarmonyOS Sans SC", -apple-system, BlinkMacSystemFont, sans-serif;
}

.placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
}

.placeholder__title {
  font-size: 40rpx;
  color: #0D8456;
}

.placeholder__hint {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #85907A;
}
